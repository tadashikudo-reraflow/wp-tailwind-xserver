{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{ "slug": "primary", "color": "#7FB8E6", "name": "Primary" },
				{ "slug": "primary-light", "color": "#A2C6E9", "name": "Primary Light" },
				{ "slug": "primary-dark", "color": "#5A9BD4", "name": "Primary Dark" },
				{ "slug": "accent", "color": "#FFF5D1", "name": "Accent" },
				{ "slug": "emphasis", "color": "#4A90E2", "name": "Emphasis" },
				{ "slug": "emphasis-dark", "color": "#357ABD", "name": "Emphasis Dark" },
				{ "slug": "text", "color": "#333333", "name": "Text" },
				{ "slug": "text-light", "color": "#666666", "name": "Text Light" },
				{ "slug": "white", "color": "#FFFFFF", "name": "White" },
				{ "slug": "surface", "color": "#F5F5F5", "name": "Surface" },
				{ "slug": "border", "color": "#E6E7EA", "name": "Border" }
			],
			"gradients": [
				{
					"slug": "hero",
					"gradient": "linear-gradient(135deg, #7FB8E6 0%, #A2C6E9 30%, #FDFBD4 70%, #FCEEEB 100%)",
					"name": "Hero"
				},
				{
					"slug": "footer",
					"gradient": "linear-gradient(135deg, #3A6EA8 0%, #4A85C5 40%, #5A9BD4 70%, #7FB8E6 100%)",
					"name": "Footer"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Noto Sans JP', sans-serif",
					"slug": "noto-sans-jp",
					"name": "Noto Sans JP"
				},
				{
					"fontFamily": "'Inter', sans-serif",
					"slug": "inter",
					"name": "Inter"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.5rem", "name": "Large" },
				{ "slug": "x-large", "size": "2rem", "name": "X-Large" },
				{ "slug": "xx-large", "size": "2.5rem", "name": "XX-Large" },
				{ "slug": "display", "size": "3.5rem", "name": "Display" },
				{ "slug": "display-en", "size": "5rem", "name": "Display English" }
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--noto-sans-jp)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.8"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--emphasis)" },
				":hover": { "color": { "text": "var(--wp--preset--color--emphasis-dark)" } }
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)", "fontWeight": "700", "lineHeight": "1.4" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)", "fontWeight": "700", "lineHeight": "1.4" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)", "fontWeight": "600", "lineHeight": "1.5" } }
		},
		"blocks": {}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "front-page", "title": "Front Page", "postTypes": ["page"] },
		{ "name": "page", "title": "Page", "postTypes": ["page"] }
	]
}
